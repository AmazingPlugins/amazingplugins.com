---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="logo" aria-label="AmazingPlugins Home">
          <img src="/images/logo.png" alt="AmazingPlugins" width="28" height="28" />
          <span>AmazingPlugins</span>
        </a>
        <p class="tagline">WordPress plugins built by a developer who uses them.</p>
      </div>

      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-col">
          <h3>Plugins</h3>
          <ul>
            <li><a href="/plugins/woocommerce-accessibility-fixer">WooCommerce Accessibility Fixer</a></li>
            <li><a href="/plugins">All Plugins</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h3>Legal</h3>
          <ul>
            <li><a href="/privacy">Privacy Policy</a></li>
            <li><a href="/terms">Terms of Service</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} AmazingPlugins. All rights reserved.</p>
      <p class="footer-tagline">Built with care. No bloated free trials.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-text);
    color: #d1d5db;
    padding: 4rem 0 2rem;
    margin-top: auto;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .footer-brand .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
  }

  .footer-brand .logo:hover {
    text-decoration: none;
    color: #93c5fd;
  }

  .tagline {
    font-size: 0.875rem;
    color: #9ca3af;
    max-width: 24ch;
    line-height: 1.5;
  }

  .footer-nav {
    display: flex;
    gap: 4rem;
  }

  .footer-col h3 {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #fff;
    margin-bottom: 1rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col a {
    color: #9ca3af;
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.15s;
  }

  .footer-col a:hover {
    color: #fff;
    text-decoration: none;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    font-size: 0.875rem;
    color: #6b7280;
  }

  .footer-tagline {
    font-size: 0.8125rem;
    color: #4b5563;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .footer-nav {
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
