---
interface Props {
  headline?: string;
  subhead?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  headline = "Small plugins. Real fixes.",
  subhead = "Tools for Shopify and WooCommerce store owners who are tired of workarounds.",
  ctaLabel = "Browse plugins",
  ctaHref = "/plugins",
  secondaryLabel = "Get Pro",
  secondaryHref = "/pricing",
} = Astro.props;
---

<section class="hero">
  <div class="hero__inner">
    <h1 class="hero__headline">{headline}</h1>
    <p class="hero__subhead">{subhead}</p>
    <div class="hero__actions">
      <a href={ctaHref} class="btn btn--primary">{ctaLabel}</a>
      <a href={secondaryHref} class="btn btn--ghost">{secondaryLabel}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--cream, #FAF5EC);
    color: var(--ink, #1A1410);
    padding: clamp(72px, 12vh, 140px) clamp(20px, 4vw, 56px);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 60% at 70% 20%,
      color-mix(in srgb, var(--coral, #F26B3A) 12%, transparent),
      transparent 70%
    ),
    radial-gradient(
      ellipse 60% 50% at 20% 80%,
      color-mix(in srgb, var(--plum, #5B3A6B) 10%, transparent),
      transparent 70%
    );
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    max-width: 760px;
  }

  .hero__headline {
    font-family: var(--font-display, 'Fraunces', serif);
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink, #1A1410);
    margin-bottom: 24px;
  }

  .hero__subhead {
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: clamp(17px, 2vw, 20px);
    line-height: 1.6;
    color: var(--ink, #1A1410);
    opacity: 0.72;
    max-width: 52ch;
    margin-bottom: 40px;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  .btn {
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: 15px;
    font-weight: 600;
    padding: 14px 24px;
    border-radius: 8px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .btn:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .btn--primary {
    background-color: var(--coral, #F26B3A);
    color: #fff;
  }

  .btn--ghost {
    background-color: transparent;
    color: var(--plum, #5B3A6B);
    border: 1.5px solid var(--plum, #5B3A6B);
  }
</style>
