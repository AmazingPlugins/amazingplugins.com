---
import BaseLayout from '../layouts/BaseLayout.astro';

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "AmazingPlugins",
  "url": "https://amazingplugins.com",
  "logo": "https://amazingplugins.com/images/logo.png",
  "sameAs": [
    "https://twitter.com/amazingplugins"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "support@amazingplugins.com",
    "contactType": "customer support"
  }
};

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "AmazingPlugins Products",
  "itemListElement": [
    {
      "@type": "SoftwareApplication",
      "position": 1,
      "name": "WooCommerce Accessibility Fixer",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "WooCommerce",
      "url": "https://amazingplugins.com/plugins/woocommerce-accessibility-fixer",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    },
    {
      "@type": "SoftwareApplication",
      "position": 2,
      "name": "Shopify Accessibility Fixer",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Shopify",
      "url": "https://amazingplugins.com/plugins/shopify-accessibility-fixer",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    }
  ]
};
---

<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />

<BaseLayout title="Plugins That Actually Work — WooCommerce & Shopify" description="No crippled free versions, no bait-and-switch pricing. Just tools that save you time.">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">🚀 Free Plugins Available Now</div>
      <h1 class="hero-title">Plugins built<br />by a developer<br />who uses them.</h1>
      <p class="hero-sub">
        No crippled free versions. No bait-and-switch pricing.<br />
        Just tools that save you time — for WooCommerce and Shopify stores.
      </p>
      <div class="hero-actions">
        <a href="/plugins" class="btn btn-primary btn-lg">
          See All Plugins
        </a>
        <a href="/plugins/shopify-accessibility-fixer" class="btn btn-outline btn-lg">
          Shopify Accessibility Fixer
        </a>
      </div>
      <p class="hero-trust">Free versions that actually work. No credit card required.</p>
    </div>
  </section>

  <!-- Pain -->
  <section class="section section-alt pain-section">
    <div class="container">
      <div class="pain-card">
        <p class="pain-text">
          WooCommerce's built-in bulk editor times out, loses changes, and cannot touch variations.
          You end up editing products one by one. That is not bulk editing.
          That is data entry.
        </p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section">
    <div class="container">
      <h2 class="text-center section-title">What Makes This Different</h2>
      <div class="grid-3">
        <article class="card feature-card">
          <div class="feature-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <rect width="40" height="40" rx="10" fill="#dbeafe"/>
              <path d="M20 12v8M20 24v4" stroke="#2563eb" stroke-width="2.5" stroke-linecap="round"/>
              <circle cx="20" cy="20" r="3" fill="#2563eb"/>
            </svg>
          </div>
          <h3>Free version that works</h3>
          <p>Edit all core fields, including variations, without paying. Not a demo. Not 10-products-per-page. A real tool.</p>
        </article>

        <article class="card feature-card">
          <div class="feature-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <rect width="40" height="40" rx="10" fill="#d1fae5"/>
              <path d="M13 20l5 5 9-9" stroke="#059669" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Preview before you save</h3>
          <p>See exactly what will change before committing. Red for old values, green for new. No more praying after a bulk update.</p>
        </article>

        <article class="card feature-card">
          <div class="feature-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <rect width="40" height="40" rx="10" fill="#fef3c7"/>
              <path d="M20 14v12M14 20h12" stroke="#d97706" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M14 28l-2-2M26 28l2-2" stroke="#d97706" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Built-in undo</h3>
          <p>Made a mistake? Roll it back in one click. Your data is safe. Always.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="text-center section-title">The Plugins</h2>
      <div class="products-list">

        <article class="product-item">
          <div class="product-content">
            <div class="product-badge">Free + Pro</div>
            <h3>WooCommerce Accessibility Fixer</h3>
            <p>Fix 10 common accessibility issues on your WooCommerce store in one click. Alt text, keyboard navigation, focus indicators, ARIA labels, and more. The free version covers most stores. Pro adds batch scanning and priority support.</p>
            <div class="product-actions">
              <a href="/plugins/woocommerce-accessibility-fixer" class="btn btn-primary">Learn More</a>
              <a href="https://wordpress.org/plugins/woocommerce-accessibility-fixer/" class="btn btn-outline" target="_blank" rel="noopener">Free on WordPress.org →</a>
            </div>
          </div>
          <div class="product-visual" aria-hidden="true">
            <div class="visual-box">
              <div class="visual-row"><span class="visual-dot green"></span>Alt text fixed</div>
              <div class="visual-row"><span class="visual-dot green"></span>Keyboard nav improved</div>
              <div class="visual-row"><span class="visual-dot green"></span>Focus indicators added</div>
              <div class="visual-row"><span class="visual-dot green"></span>ARIA labels added</div>
              <div class="visual-row"><span class="visual-dot green"></span>Color contrast checked</div>
              <div class="visual-row muted">+5 more fixes</div>
            </div>
          </div>
        </article>

        <article class="product-item">
          <div class="product-content">
            <div class="product-badge" style="background:#d1fae5;color:#065f46;">Free + Pro</div>
            <h3>Shopify Accessibility Fixer</h3>
            <p>The same 10 accessibility fixes, built for Shopify. Alt text, keyboard navigation, focus indicators, ARIA labels — all without an overlay. Real WCAG 2.1 AA compliance, not a JavaScript patch. Free version covers most stores. Pro adds batch scanning and PDF compliance reports.</p>
            <div class="product-actions">
              <a href="/plugins/shopify-accessibility-fixer" class="btn btn-primary">Learn More</a>
            </div>
          </div>
          <div class="product-visual" aria-hidden="true">
            <div class="visual-box">
              <div class="visual-row"><span class="visual-dot green"></span>Alt text fixed</div>
              <div class="visual-row"><span class="visual-dot green"></span>Keyboard nav improved</div>
              <div class="visual-row"><span class="visual-dot green"></span>Focus indicators added</div>
              <div class="visual-row"><span class="visual-dot green"></span>ARIA labels added</div>
              <div class="visual-row"><span class="visual-dot green"></span>Color contrast checked</div>
              <div class="visual-row muted">+5 more fixes</div>
            </div>
          </div>
        </article>

        <article class="product-item coming-soon">
          <div class="product-content">
            <div class="product-badge badge-soon">Coming Soon</div>
            <h3>Order Fixer for WooCommerce</h3>
            <p>Edit orders without killing the math. Inline quantity edits, item removal, new item additions with variant search — all with automatic totals recalculation and audit logging. Because WooCommerce should let you fix honest mistakes.</p>
            <div class="product-actions">
              <span class="btn btn-outline" style="opacity:0.5;cursor:not-allowed">Coming Soon</span>
            </div>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container text-center">
      <h2>Stop doing data entry. Start shipping.</h2>
      <p class="cta-sub">Your store deserves better than one-by-one editing. Pick your platform and get started free.</p>
      <a href="/plugins" class="btn btn-primary btn-lg">
        Browse All Plugins →
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 7rem 0 5rem;
    background: linear-gradient(180deg, #eff6ff 0%, #fff 100%);
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    background: #dbeafe;
    color: #1d4ed8;
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.375rem 0.875rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.05;
    color: #0f172a;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: #475569;
    max-width: 48ch;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .hero-trust {
    font-size: 0.875rem;
    color: #6b7280;
  }

  /* Pain */
  .pain-card {
    max-width: 65ch;
    margin: 0 auto;
    text-align: center;
  }

  .pain-text {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    color: #374151;
    line-height: 1.7;
    font-style: italic;
    border-left: 4px solid var(--color-primary);
    padding-left: 1.5rem;
    text-align: left;
  }

  /* Section title */
  .section-title {
    margin-bottom: 3rem;
  }

  /* Features */
  .feature-card h3 {
    font-size: 1.125rem;
    margin: 1rem 0 0.5rem;
  }

  .feature-card p {
    color: var(--color-text-light);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  /* Products */
  .products-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .product-item {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    padding: 3rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
  }

  .product-item.coming-soon {
    opacity: 0.7;
  }

  .product-badge {
    display: inline-block;
    background: #dbeafe;
    color: #1d4ed8;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    margin-bottom: 0.75rem;
  }

  .badge-soon {
    background: #fef3c7;
    color: #92400e;
  }

  .product-content h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .product-content p {
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .product-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .visual-box {
    background: #f8fafc;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    font-size: 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .visual-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .visual-row.muted {
    color: #9ca3af;
    font-style: italic;
    padding-left: 1.375rem;
  }

  .visual-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .visual-dot.green {
    background: #22c55e;
    box-shadow: 0 0 6px rgba(34,197,94,0.4);
  }

  /* CTA */
  .cta-section {
    background: #0f172a;
    color: #fff;
  }

  .cta-section h2 {
    color: #fff;
    margin-bottom: 1rem;
  }

  .cta-sub {
    color: #94a3b8;
    margin-bottom: 2rem;
    font-size: 1.125rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 4rem 0 3rem;
    }

    .product-item {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 1.5rem;
    }

    .product-visual {
      order: -1;
    }
  }
</style>
