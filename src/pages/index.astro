---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="A house of plugins for Shopify and WooCommerce" description="Small, sharp tools that fix real problems for store owners. Some free, some paid, all crafted.">

  <!-- Hero -->
  <section class="hero-wrap" id="hero-section">
    <div class="ribbon-bg ribbon-anim" style="top:-120px;right:-200px;width:1100px;opacity:0.55;" aria-hidden="true">
      <svg viewBox="0 0 1000 320" fill="none" width="1100">
        <defs><linearGradient id="rg-a" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#F4A93C" stop-opacity="0.9"/><stop offset="40%" stop-color="#F26B3A"/><stop offset="70%" stop-color="#E85A78"/><stop offset="100%" stop-color="#5B3A6B"/></linearGradient></defs>
        <path d="M 50 200 Q 200 80 380 180 T 720 220 Q 880 240 950 120" stroke="url(#rg-a)" stroke-width="64" stroke-linecap="round" fill="none"/>
        <path d="M 50 200 Q 200 80 380 180 T 720 220 Q 880 240 950 120" stroke="rgba(255,255,255,0.25)" stroke-width="20" stroke-linecap="round" fill="none"/>
      </svg>
    </div>
    <div class="ribbon-bg ribbon-anim" style="bottom:-200px;left:-150px;width:900px;opacity:0.22;animation-delay:2s;" aria-hidden="true">
      <svg viewBox="0 0 1000 320" fill="none" width="900">
        <defs><linearGradient id="rg-b" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#F4A93C" stop-opacity="0.9"/><stop offset="40%" stop-color="#F26B3A"/><stop offset="70%" stop-color="#E85A78"/><stop offset="100%" stop-color="#5B3A6B"/></linearGradient></defs>
        <path d="M 0 100 Q 200 220 400 140 T 800 200" stroke="url(#rg-b)" stroke-width="64" stroke-linecap="round" fill="none"/>
        <path d="M 0 100 Q 200 220 400 140 T 800 200" stroke="rgba(255,255,255,0.25)" stroke-width="20" stroke-linecap="round" fill="none"/>
      </svg>
    </div>
    <div class="grain"></div>
    <div class="wrap hero-content">
      <div class="chip" style="margin-bottom:36px;">
        <span class="chip-dot"></span>
        <span>A small studio. Eight plugins. Two platforms.</span>
      </div>
      <h1 class="display hero-h1">
        A <em>house</em> of plugins for Shopify and WooCommerce.
      </h1>
      <p class="lede hero-lede">
        We build small, sharp tools that fix real problems for store owners. Some are free, some are paid, all are crafted with the patience of someone who runs a store too.
      </p>
      <div class="hero-btns">
        <a href="/plugins" class="btn btn-primary" style="padding:16px 28px;font-size:16px;">
          Browse plugins
          <svg viewBox="0 0 16 16" fill="none" width="14" height="14"><path d="M3 8h10m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>
        <a href="/pricing" class="btn btn-ghost" style="padding:16px 28px;font-size:16px;">
          Get Pro
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section" style="padding-top:40px;">
    <div class="wrap">
      <div class="stats">
        <div class="stat">
          <div class="stat-num count-up" data-target="12400">0<span class="unit">+</span></div>
          <div class="stat-lbl">stores running our plugins</div>
        </div>
        <div class="stat">
          <div class="stat-num">8</div>
          <div class="stat-lbl">plugins shipped, no bloat</div>
        </div>
        <div class="stat">
          <div class="stat-num">4</div>
          <div class="stat-lbl">free, 4 paid, 2 freemium</div>
        </div>
        <div class="stat">
          <div class="stat-num">4.9<span class="unit">/5</span></div>
          <div class="stat-lbl">across 2,300 reviews</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Plugin Tiles -->
  <section class="section">
    <div class="wrap">
      <div class="catalog-header">
        <div>
          <div class="eyebrow" style="margin-bottom:16px;">The catalog</div>
          <h2 class="display" style="font-size:clamp(36px,5vw,72px);max-width:18ch;">
            Eight rooms, one <em>house</em>.
          </h2>
        </div>
        <a href="/plugins" class="btn btn-ghost">
          View all plugins
          <svg viewBox="0 0 16 16" fill="none" width="14" height="14"><path d="M3 8h10m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>
      </div>
      <div class="tiles-grid">
        <a href="/plugins/shopify-accessibility-fixer" class="tile tile-grad-1" style="padding:32px;min-height:240px;display:flex;flex-direction:column;justify-content:space-between;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;">
            <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;opacity:0.85;">01 · Shopify</span>
            <span class="price-tag price-tag-dark">Pro</span>
          </div>
          <h3 class="display" style="font-size:32px;letter-spacing:-0.02em;line-height:1.05;">Accessibility Fixer</h3>
        </a>
        <a href="/plugins/woocommerce-accessibility-fixer" class="tile tile-grad-2" style="padding:32px;min-height:240px;display:flex;flex-direction:column;justify-content:space-between;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;">
            <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;opacity:0.85;">02 · WooCommerce</span>
            <span class="price-tag price-tag-dark">Pro</span>
          </div>
          <h3 class="display" style="font-size:32px;letter-spacing:-0.02em;line-height:1.05;">Accessibility Fixer</h3>
        </a>
        <a href="/plugins" class="tile tile-grad-3" style="padding:32px;min-height:240px;display:flex;flex-direction:column;justify-content:space-between;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;">
            <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;opacity:0.85;">03 · WooCommerce</span>
            <span class="price-tag price-tag-dark">Free + Pro</span>
          </div>
          <h3 class="display" style="font-size:32px;letter-spacing:-0.02em;line-height:1.05;">Bulk Edit Pro</h3>
        </a>
        <a href="/plugins" class="tile tile-grad-4" style="padding:32px;min-height:240px;display:flex;flex-direction:column;justify-content:space-between;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;">
            <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;opacity:0.85;">04 · Shopify</span>
            <span class="price-tag price-tag-dark">Pro</span>
          </div>
          <h3 class="display" style="font-size:32px;letter-spacing:-0.02em;line-height:1.05;">Digital Delivery</h3>
        </a>
        <a href="/plugins" class="tile tile-grad-cream" style="padding:32px;min-height:240px;display:flex;flex-direction:column;justify-content:space-between;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;">
            <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;opacity:0.55;">05 · Both</span>
            <span class="price-tag price-free">Free</span>
          </div>
          <h3 class="display" style="font-size:32px;letter-spacing:-0.02em;line-height:1.05;">Inventory Sync</h3>
        </a>
        <a href="/plugins" class="tile tile-grad-cream" style="padding:32px;min-height:240px;display:flex;flex-direction:column;justify-content:space-between;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;">
            <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;opacity:0.55;">06 · Both</span>
            <span class="price-tag price-free">Free</span>
          </div>
          <h3 class="display" style="font-size:32px;letter-spacing:-0.02em;line-height:1.05;">Review Importer</h3>
        </a>
      </div>
    </div>
  </section>

  <!-- Beliefs -->
  <section class="section">
    <div class="wrap">
      <div class="beliefs-header">
        <div><div class="eyebrow" style="margin-bottom:16px;">What we believe</div></div>
        <h2 class="display" style="font-size:clamp(36px,5vw,64px);max-width:20ch;">
          Quiet plugins. Loud results. <em>No nonsense</em> in between.
        </h2>
      </div>
      <div class="beliefs-grid">
        <div class="belief-cell">
          <div style="font-family:var(--font-mono);font-size:11px;color:var(--coral);letter-spacing:0.14em;margin-bottom:28px;text-transform:uppercase;">01 · Small</div>
          <h3 class="display" style="font-size:28px;margin-bottom:16px;letter-spacing:-0.02em;">Two people, one shared inbox.</h3>
          <p style="font-size:15px;color:var(--ink-2);line-height:1.55;">You write us, one of us writes back. Probably the person who built the thing you are asking about.</p>
        </div>
        <div class="belief-cell">
          <div style="font-family:var(--font-mono);font-size:11px;color:var(--coral);letter-spacing:0.14em;margin-bottom:28px;text-transform:uppercase;">02 · Sharp</div>
          <h3 class="display" style="font-size:28px;margin-bottom:16px;letter-spacing:-0.02em;">One plugin, one job.</h3>
          <p style="font-size:15px;color:var(--ink-2);line-height:1.55;">No suite, no upsell tabs inside the dashboard. Each plugin solves one specific problem and gets out of the way.</p>
        </div>
        <div class="belief-cell">
          <div style="font-family:var(--font-mono);font-size:11px;color:var(--coral);letter-spacing:0.14em;margin-bottom:28px;text-transform:uppercase;">03 · Honest</div>
          <h3 class="display" style="font-size:28px;margin-bottom:16px;letter-spacing:-0.02em;">The price you sign at is the price you renew at.</h3>
          <p style="font-size:15px;color:var(--ink-2);line-height:1.55;">No surprise increases, no usage cliffs, no walls in front of the basics. Cancel anytime, take your data with you.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Platform picker -->
  <section class="section" style="background:var(--cream-2);">
    <div class="wrap">
      <div class="eyebrow" style="margin-bottom:16px;">Pick your platform</div>
      <h2 class="display" style="font-size:clamp(36px,5vw,64px);margin-bottom:56px;max-width:18ch;">
        Two platforms, same studio.
      </h2>
      <div class="platform-grid">
        <a href="/plugins" class="card" style="padding:40px;display:block;cursor:pointer;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:36px;">
            <div class="eyebrow" style="color:var(--coral);">Plus, Advanced, and standard plans</div>
            <svg width="20" height="20" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <h3 class="display" style="font-size:56px;margin-bottom:18px;letter-spacing:-0.03em;">Shopify</h3>
          <p style="color:var(--ink-2);max-width:32ch;">Embedded apps. No theme edits. Works with Liquid, Hydrogen, and Online Store 2.0.</p>
        </a>
        <a href="/plugins" class="card" style="padding:40px;display:block;cursor:pointer;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:36px;">
            <div class="eyebrow" style="color:var(--plum);">WordPress 6.4+, WooCommerce 8.0+</div>
            <svg width="20" height="20" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <h3 class="display" style="font-size:56px;margin-bottom:18px;letter-spacing:-0.03em;">WooCommerce</h3>
          <p style="color:var(--ink-2);max-width:32ch;">Standard WP plugin install. FSE themes, classic themes, every WooCommerce-compatible builder.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- How we ship -->
  <section class="section">
    <div class="wrap">
      <div class="eyebrow" style="margin-bottom:16px;">How we ship</div>
      <h2 class="display" style="font-size:clamp(36px,5vw,64px);margin-bottom:56px;max-width:20ch;">
        The promises behind every <em>plugin</em>.
      </h2>
      <div class="principles-grid">
        <div class="card" style="padding:36px;">
          <div style="display:flex;gap:20px;align-items:baseline;margin-bottom:14px;">
            <span style="font-family:var(--font-mono);font-size:12px;color:var(--coral);letter-spacing:0.14em;">01</span>
            <h3 class="display" style="font-size:26px;letter-spacing:-0.015em;flex:1;">Real audits, not overlays</h3>
          </div>
          <p style="font-size:15px;color:var(--ink-2);line-height:1.6;padding-left:44px;">Our accessibility plugins fix the underlying markup. No iframe widget that hides issues from your audit but leaves them in your code.</p>
        </div>
        <div class="card" style="padding:36px;">
          <div style="display:flex;gap:20px;align-items:baseline;margin-bottom:14px;">
            <span style="font-family:var(--font-mono);font-size:12px;color:var(--coral);letter-spacing:0.14em;">02</span>
            <h3 class="display" style="font-size:26px;letter-spacing:-0.015em;flex:1;">Every plugin ships with rollback</h3>
          </div>
          <p style="font-size:15px;color:var(--ink-2);line-height:1.6;padding-left:44px;">Bulk operations preview their changes before they run, and one click reverts the whole batch. We refuse to ship destructive features without an undo.</p>
        </div>
        <div class="card" style="padding:36px;">
          <div style="display:flex;gap:20px;align-items:baseline;margin-bottom:14px;">
            <span style="font-family:var(--font-mono);font-size:12px;color:var(--coral);letter-spacing:0.14em;">03</span>
            <h3 class="display" style="font-size:26px;letter-spacing:-0.015em;flex:1;">Two-week release cadence</h3>
          </div>
          <p style="font-size:15px;color:var(--ink-2);line-height:1.6;padding-left:44px;">Predictable, small, boring releases. Changelogs in plain English. No marketing blasts dressed up as product updates.</p>
        </div>
        <div class="card" style="padding:36px;">
          <div style="display:flex;gap:20px;align-items:baseline;margin-bottom:14px;">
            <span style="font-family:var(--font-mono);font-size:12px;color:var(--coral);letter-spacing:0.14em;">04</span>
            <h3 class="display" style="font-size:26px;letter-spacing:-0.015em;flex:1;">You own your data on the way out</h3>
          </div>
          <p style="font-size:15px;color:var(--ink-2);line-height:1.6;padding-left:44px;">Cancel a plugin and we hand back a clean export. No lock-in, no held-hostage settings, no confused renewal flows.</p>
        </div>
      </div>
      <div class="studio-stats">
        <div><div class="display" style="font-size:40px;letter-spacing:-0.025em;">2</div><div style="font-size:13px;color:var(--ink-3);">people in the studio</div></div>
        <div><div class="display" style="font-size:40px;letter-spacing:-0.025em;">14d</div><div style="font-size:13px;color:var(--ink-3);">release cadence</div></div>
        <div><div class="display" style="font-size:40px;letter-spacing:-0.025em;">~6h</div><div style="font-size:13px;color:var(--ink-3);">support response</div></div>
        <div><div class="display" style="font-size:40px;letter-spacing:-0.025em;">30d</div><div style="font-size:13px;color:var(--ink-3);">full refund window</div></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-dark">
    <div class="ribbon-bg ribbon-anim" style="top:-30%;right:-20%;width:1200px;opacity:0.65;" aria-hidden="true">
      <svg viewBox="0 0 1000 320" fill="none" width="1200">
        <defs><linearGradient id="rg-cta" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#F4A93C" stop-opacity="0.9"/><stop offset="40%" stop-color="#F26B3A"/><stop offset="70%" stop-color="#E85A78"/><stop offset="100%" stop-color="#5B3A6B"/></linearGradient></defs>
        <path d="M 50 200 Q 200 80 380 180 T 720 220 Q 880 240 950 120" stroke="url(#rg-cta)" stroke-width="64" stroke-linecap="round" fill="none"/>
        <path d="M 50 200 Q 200 80 380 180 T 720 220 Q 880 240 950 120" stroke="rgba(255,255,255,0.25)" stroke-width="20" stroke-linecap="round" fill="none"/>
      </svg>
    </div>
    <div class="wrap" style="position:relative;">
      <h2 class="display cta-h2">
        Find the plugin you actually <em>need</em>.
      </h2>
      <p style="font-size:18px;color:rgba(244,236,219,0.7);max-width:50ch;margin-bottom:40px;">
        Eight plugins, four free. Browse the catalog or jump straight to Pro for everything in one place.
      </p>
      <div style="display:flex;gap:14px;flex-wrap:wrap;">
        <a href="/plugins" class="btn btn-coral" style="padding:16px 28px;font-size:16px;">
          Browse plugins
          <svg viewBox="0 0 16 16" fill="none" width="14" height="14"><path d="M3 8h10m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>
        <a href="/pricing" class="btn" style="padding:16px 28px;font-size:16px;color:var(--cream);border:1px solid rgba(244,236,219,0.25);">
          Get Pro
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // Count-up animation for stats
  document.querySelectorAll('.count-up[data-target]').forEach(el => {
    const target = parseInt((el as HTMLElement).dataset.target || '0');
    const unit = el.querySelector('.unit')?.outerHTML || '';
    const obs = new IntersectionObserver(entries => {
      if (!entries[0].isIntersecting) return;
      obs.disconnect();
      const start = performance.now();
      const duration = 1400;
      function tick(now: number) {
        const p = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - p, 3);
        const n = Math.round(target * eased);
        el.innerHTML = n.toLocaleString() + unit;
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }, { threshold: 0.4 });
    obs.observe(el);
  });
</script>

<style>
  .hero-wrap {
    position: relative;
    overflow: hidden;
    padding-top: 80px;
    padding-bottom: 120px;
  }
  .hero-content {
    position: relative;
    z-index: 2;
  }
  .hero-h1 {
    font-size: clamp(56px, 8.5vw, 132px);
    max-width: 14ch;
    margin-bottom: 32px;
  }
  .hero-lede {
    margin-bottom: 40px;
  }
  .hero-btns {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .catalog-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 56px;
    gap: 24px;
    flex-wrap: wrap;
  }
  .tiles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .beliefs-header {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 64px;
    align-items: start;
    margin-bottom: 64px;
  }
  .beliefs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
  }
  .belief-cell {
    background: var(--cream);
    padding: 36px;
    min-height: 320px;
  }

  .platform-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .principles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .studio-stats {
    margin-top: 56px;
    padding: 40px 48px;
    background: var(--cream-2);
    border-radius: 16px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .cta-dark {
    background: var(--ink);
    color: var(--cream);
    padding: 120px 0;
    position: relative;
    overflow: hidden;
  }
  .cta-h2 {
    font-size: clamp(48px, 7vw, 96px);
    max-width: 14ch;
    margin-bottom: 32px;
    color: var(--cream);
  }

  @media (max-width: 900px) {
    .tiles-grid { grid-template-columns: repeat(2, 1fr); }
    .beliefs-header { grid-template-columns: 1fr; gap: 24px; }
    .beliefs-grid { grid-template-columns: 1fr; }
    .platform-grid { grid-template-columns: 1fr; }
    .principles-grid { grid-template-columns: 1fr; }
    .studio-stats { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .tiles-grid { grid-template-columns: 1fr; }
    .studio-stats { grid-template-columns: 1fr 1fr; padding: 28px; }
  }
</style>
