---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pricing" description="Free WordPress plugins with optional Pro plans. No monthly fees, no bait-and-switch.">
  <section class="section">
    <div class="container">
      <div class="pricing-header">
        <h1>Free to start. No monthly fees.</h1>
        <p>Every plugin installs free. Upgrade only when you need the features that actually matter.</p>
      </div>

      <div class="pricing-grid">

        <!-- WooCommerce Accessibility Fixer -->
        <div class="pricing-card">
          <div class="pricing-card-header">
            <div class="plugin-badge">WordPress</div>
            <h2>WooCommerce Accessibility Fixer</h2>
            <p>WCAG 2.1 AA compliance for your store</p>
          </div>
          <div class="plan-summary">
            <div class="plan-row">
              <span class="plan-label">Free</span>
              <span class="plan-desc">3 fixes, unlimited scans, basic reports</span>
            </div>
            <div class="plan-row pro">
              <span class="plan-label">Pro</span>
              <span class="plan-desc">All 10 fixes, PDF reports, auto-rescan, priority support</span>
            </div>
          </div>
          <a href="/plugins/woocommerce-accessibility-fixer#pricing" class="btn btn-primary">Get PRO</a>
          <a href="/plugins/woocommerce-accessibility-fixer" class="btn btn-secondary">Learn more</a>
        </div>

        <!-- Shopify Accessibility Fixer -->
        <div class="pricing-card">
          <div class="pricing-card-header">
            <div class="plugin-badge shopify">Shopify</div>
            <h2>Shopify Accessibility Fixer</h2>
            <p>WCAG 2.1 AA compliance for Shopify stores</p>
          </div>
          <div class="plan-summary">
            <div class="plan-row">
              <span class="plan-label">Free</span>
              <span class="plan-desc">3 fixes, unlimited scans, basic reports</span>
            </div>
            <div class="plan-row pro">
              <span class="plan-label">Agency</span>
              <span class="plan-desc">Unlimited stores, white-label reports, dedicated support</span>
            </div>
          </div>
          <a href="/plugins/shopify-accessibility-fixer" class="btn btn-primary">Get PRO</a>
          <a href="/plugins/shopify-accessibility-fixer" class="btn btn-secondary">Learn more</a>
        </div>

        <!-- WooCommerce Smart Bulk Editor -->
        <div class="pricing-card">
          <div class="pricing-card-header">
            <div class="plugin-badge">WordPress</div>
            <h2>WooCommerce Smart Bulk Editor</h2>
            <p>Edit your entire catalog without the pain</p>
          </div>
          <div class="plan-summary">
            <div class="plan-row">
              <span class="plan-label">Free</span>
              <span class="plan-desc">Inline editing, variation support, filter by anything</span>
            </div>
            <div class="plan-row pro">
              <span class="plan-label">Pro</span>
              <span class="plan-desc">Saved presets, scheduled operations, CSV import/export</span>
            </div>
          </div>
          <div class="coming-soon-tag">Coming soon</div>
        </div>

      </div>

      <div class="pricing-faq">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-grid">
          <div class="faq-item">
            <h3>Do I need a credit card to start free?</h3>
            <p>No. Every plugin installs free from your WordPress admin or the Shopify App Store. No credit card required.</p>
          </div>
          <div class="faq-item">
            <h3>Can I cancel anytime?</h3>
            <p>Yes. Annual plans can be cancelled before renewal. Your plugin keeps working -- you just lose Pro features at the end of the billing period.</p>
          </div>
          <div class="faq-item">
            <h3>What happens to my data if I cancel?</h3>
            <p>Nothing. Your settings and scan history are preserved. Reactivating Pro is a one-click license key entry.</p>
          </div>
          <div class="faq-item">
            <h3>Do you offer refunds?</h3>
            <p>Yes, within 14 days of purchase for any reason -- just email support.</p>
          </div>
          <div class="faq-item">
            <h3>Can I use these on client stores?</h3>
            <p>Yes with an Agency plan. The Agency tier covers up to 25 stores and includes white-label compliance reports.</p>
          </div>
          <div class="faq-item">
            <h3>Do these work with my existing theme and plugins?</h3>
            <p>Both plugins are built to be compatible with any standards-compliant WordPress theme and most popular WooCommerce extensions. If you hit a conflict, we will fix it.</p>
          </div>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .pricing-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 4rem;
  }

  .pricing-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin: 0 0 1rem;
  }

  .pricing-header p {
    font-size: 1.1rem;
    color: var(--color-text-light);
    margin: 0;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 5rem;
  }

  .pricing-card {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 1.5rem;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .pricing-card-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .plugin-badge {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: fit-content;
  }

  .plugin-badge.shopify {
    background: #5C6AC4;
  }

  .pricing-card-header h2 {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0;
  }

  .pricing-card-header p {
    color: var(--color-text-light);
    font-size: 0.875rem;
    margin: 0;
  }

  .plan-summary {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    background: white;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
  }

  .plan-row {
    display: flex;
    gap: 0.75rem;
    font-size: 0.85rem;
    align-items: baseline;
  }

  .plan-row.pro .plan-label {
    color: var(--color-primary);
  }

  .plan-label {
    font-weight: 700;
    min-width: 52px;
    color: var(--color-text);
  }

  .plan-desc {
    color: var(--color-text-light);
  }

  .btn {
    display: block;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    transition: all 0.2s;
    cursor: pointer;
    border: none;
    font-size: 0.9rem;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-primary-dark);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: var(--color-bg-alt);
  }

  .coming-soon-tag {
    display: inline-block;
    text-align: center;
    padding: 0.75rem;
    border-radius: 0.5rem;
    background: var(--color-bg-alt);
    color: var(--color-text-light);
    font-size: 0.85rem;
    font-weight: 600;
    border: 1px dashed var(--color-border);
  }

  .pricing-faq {
    border-top: 1px solid var(--color-border);
    padding-top: 4rem;
  }

  .pricing-faq h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 2.5rem;
    text-align: center;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .faq-item h3 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--color-heading);
  }

  .faq-item p {
    color: var(--color-text-light);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }
</style>
