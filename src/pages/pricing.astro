---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pricing" description="Honest pricing. Same price next year as this year. No surprise increases. Cancel anytime.">

  <!-- Header -->
  <section style="position:relative;overflow:hidden;padding-top:80px;padding-bottom:40px;">
    <div class="ribbon-bg" style="top:-80px;right:-150px;width:900px;opacity:0.25;" aria-hidden="true">
      <svg viewBox="0 0 1000 320" fill="none" width="900">
        <defs><linearGradient id="rg-p" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#F4A93C" stop-opacity="0.9"/><stop offset="40%" stop-color="#F26B3A"/><stop offset="70%" stop-color="#E85A78"/><stop offset="100%" stop-color="#5B3A6B"/></linearGradient></defs>
        <path d="M 100 250 C 200 100, 400 350, 600 180 S 900 100, 1000 250" stroke="url(#rg-p)" stroke-width="64" stroke-linecap="round" fill="none"/>
        <path d="M 100 250 C 200 100, 400 350, 600 180 S 900 100, 1000 250" stroke="rgba(255,255,255,0.25)" stroke-width="20" stroke-linecap="round" fill="none"/>
      </svg>
    </div>
    <div class="wrap" style="position:relative;text-align:center;">
      <div class="eyebrow" style="margin-bottom:16px;">Pricing</div>
      <h1 class="display" style="font-size:clamp(56px,8vw,112px);max-width:14ch;margin:0 auto 24px;">
        Honest pricing. <em>Boring</em> renewals.
      </h1>
      <p class="lede" style="margin:0 auto 36px;text-align:center;max-width:52ch;">
        Same price next year as this year. No surprise increases. Cancel anytime — your reports are yours, exported on your way out.
      </p>
      <div id="billing-toggle" style="display:inline-flex;background:var(--cream-2);padding:4px;border-radius:999px;gap:4px;">
        <button id="btn-monthly" class="toggle-btn" style="padding:10px 20px;border-radius:999px;font-size:14px;">Monthly</button>
        <button id="btn-yearly" class="toggle-btn toggle-active" style="padding:10px 20px;border-radius:999px;font-size:14px;display:flex;gap:8px;align-items:center;">
          Yearly <span style="font-family:var(--font-mono);font-size:11px;color:var(--coral);">−20%</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Tiers -->
  <section style="padding-bottom:100px;">
    <div class="wrap">
      <div class="tiers-grid">

        <!-- Starter -->
        <div class="card tier-card">
          <div style="font-family:var(--font-mono);font-size:11px;color:var(--ink-3);text-transform:uppercase;letter-spacing:0.14em;margin-bottom:14px;">For small stores</div>
          <h2 class="display" style="font-size:36px;margin-bottom:8px;">Starter</h2>
          <p style="font-size:14px;color:var(--ink-2);margin-bottom:28px;min-height:42px;">For stores under 500 SKUs and 5,000 monthly visits.</p>
          <div style="margin-bottom:28px;display:flex;align-items:baseline;gap:6px;">
            <span class="display tier-price" data-mo="19" data-yr="15" style="font-size:64px;letter-spacing:-0.03em;">$15</span>
            <span class="tier-cadence" style="font-size:13px;color:var(--ink-3);">/mo billed annually</span>
          </div>
          <a href="/plugins" class="btn btn-primary" style="width:100%;justify-content:center;margin-bottom:28px;">Start free trial</a>
          <ul class="features-list">
            <li>1 store</li>
            <li>Up to 500 products</li>
            <li>Weekly scans</li>
            <li>Email support</li>
            <li>Basic remediation</li>
            <li>12-month report history</li>
          </ul>
        </div>

        <!-- Growth (highlight) -->
        <div class="card tier-card tier-highlight">
          <span class="chip solid" style="position:absolute;top:-12px;left:36px;background:var(--coral);color:#fff;border-color:var(--coral);">Most popular</span>
          <div style="font-family:var(--font-mono);font-size:11px;color:rgba(244,236,219,0.6);text-transform:uppercase;letter-spacing:0.14em;margin-bottom:14px;">Most popular</div>
          <h2 class="display" style="font-size:36px;margin-bottom:8px;">Growth</h2>
          <p style="font-size:14px;color:rgba(244,236,219,0.7);margin-bottom:28px;min-height:42px;">For growing stores. Daily scans, advanced remediation, priority support.</p>
          <div style="margin-bottom:28px;display:flex;align-items:baseline;gap:6px;">
            <span class="display tier-price" data-mo="49" data-yr="39" style="font-size:64px;letter-spacing:-0.03em;">$39</span>
            <span class="tier-cadence" style="font-size:13px;color:rgba(244,236,219,0.6);">/mo billed annually</span>
          </div>
          <a href="/plugins" class="btn" style="width:100%;justify-content:center;margin-bottom:28px;background:var(--coral);color:#fff;">Start free trial</a>
          <ul class="features-list features-dark">
            <li>Up to 3 stores</li>
            <li>Unlimited products</li>
            <li>Daily scans</li>
            <li>Priority chat support</li>
            <li>Advanced remediation</li>
            <li>Unlimited report history</li>
            <li>Audit-trail PDF export</li>
            <li>Slack notifications</li>
          </ul>
        </div>

        <!-- Scale -->
        <div class="card tier-card">
          <div style="font-family:var(--font-mono);font-size:11px;color:var(--ink-3);text-transform:uppercase;letter-spacing:0.14em;margin-bottom:14px;">For Shopify Plus &amp; multi-store</div>
          <h2 class="display" style="font-size:36px;margin-bottom:8px;">Scale</h2>
          <p style="font-size:14px;color:var(--ink-2);margin-bottom:28px;min-height:42px;">For multi-store and high-traffic operations.</p>
          <div style="margin-bottom:28px;display:flex;align-items:baseline;gap:6px;">
            <span class="display tier-price" data-mo="149" data-yr="119" style="font-size:64px;letter-spacing:-0.03em;">$119</span>
            <span class="tier-cadence" style="font-size:13px;color:var(--ink-3);">/mo billed annually</span>
          </div>
          <a href="mailto:support@amazingplugins.com" class="btn btn-primary" style="width:100%;justify-content:center;margin-bottom:28px;">Talk to sales</a>
          <ul class="features-list">
            <li>Unlimited stores</li>
            <li>Unlimited products</li>
            <li>Continuous scanning</li>
            <li>Dedicated CSM</li>
            <li>Custom remediation rules</li>
            <li>SAML SSO</li>
            <li>API access</li>
            <li>White-label reports</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background:var(--cream-2);">
    <div class="wrap">
      <div class="faq-layout">
        <div>
          <div class="eyebrow" style="margin-bottom:16px;">FAQ</div>
          <h2 class="display" style="font-size:clamp(36px,5vw,64px);max-width:15ch;">
            The questions we keep getting.
          </h2>
        </div>
        <div class="faq-list">
          <details>
            <summary>Do you offer discounts for non-profits?<span>+</span></summary>
            <p>Yes — 50% off any plan. Email us a copy of your registration and we'll set it up the same day.</p>
          </details>
          <details>
            <summary>What happens if my store has more SKUs than my plan allows?<span>+</span></summary>
            <p>Nothing breaks. We'll ping you and you can either upgrade or decide which products to exclude from scanning.</p>
          </details>
          <details>
            <summary>Will the plugin slow down my store?<span>+</span></summary>
            <p>No. Scans run on our servers — your store sees a single crawler request per page, like Googlebot. Remediation runs at build/save time.</p>
          </details>
          <details>
            <summary>Can I cancel any time?<span>+</span></summary>
            <p>Yes. Pro-rated refund on yearly plans, no questions asked. Your reports are exported as PDF + CSV on cancellation.</p>
          </details>
          <details>
            <summary>Are you ADA compliant yourselves?<span>+</span></summary>
            <p>We try to be. amazingplugins.com scores 100/100 on Lighthouse and 0 issues on axe. If you find something, email accessibility@amazingplugins.com.</p>
          </details>
          <details>
            <summary>Do you support headless Shopify (Hydrogen)?<span>+</span></summary>
            <p>Yes. We have a Hydrogen integration that runs at build time. Setup walkthrough is in the docs.</p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-dark">
    <div class="ribbon-bg ribbon-anim" style="top:-30%;right:-20%;width:1200px;opacity:0.65;" aria-hidden="true">
      <svg viewBox="0 0 1000 320" fill="none" width="1200">
        <defs><linearGradient id="rg-cta2" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#F4A93C" stop-opacity="0.9"/><stop offset="40%" stop-color="#F26B3A"/><stop offset="70%" stop-color="#E85A78"/><stop offset="100%" stop-color="#5B3A6B"/></linearGradient></defs>
        <path d="M 50 200 Q 200 80 380 180 T 720 220 Q 880 240 950 120" stroke="url(#rg-cta2)" stroke-width="64" stroke-linecap="round" fill="none"/>
        <path d="M 50 200 Q 200 80 380 180 T 720 220 Q 880 240 950 120" stroke="rgba(255,255,255,0.25)" stroke-width="20" stroke-linecap="round" fill="none"/>
      </svg>
    </div>
    <div class="wrap" style="position:relative;">
      <h2 class="display" style="font-size:clamp(48px,7vw,96px);max-width:14ch;margin-bottom:32px;color:var(--cream);">
        Find the plugin you actually <em>need</em>.
      </h2>
      <p style="font-size:18px;color:rgba(244,236,219,0.7);max-width:50ch;margin-bottom:40px;">
        Eight plugins, four free. Browse the catalog or jump straight to Pro for everything in one place.
      </p>
      <div style="display:flex;gap:14px;flex-wrap:wrap;">
        <a href="/plugins" class="btn btn-coral" style="padding:16px 28px;font-size:16px;">
          Browse plugins
          <svg viewBox="0 0 16 16" fill="none" width="14" height="14"><path d="M3 8h10m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>
        <a href="/plugins" class="btn" style="padding:16px 28px;font-size:16px;color:var(--cream);border:1px solid rgba(244,236,219,0.25);">
          Get Pro
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  let yearly = true;

  function updatePrices() {
    document.querySelectorAll<HTMLElement>('.tier-price').forEach(el => {
      const val = yearly ? el.dataset.yr : el.dataset.mo;
      el.textContent = '$' + val;
    });
    document.querySelectorAll<HTMLElement>('.tier-cadence').forEach(el => {
      el.textContent = yearly ? '/mo billed annually' : '/mo';
    });
    const btnM = document.getElementById('btn-monthly');
    const btnY = document.getElementById('btn-yearly');
    if (btnM && btnY) {
      btnM.classList.toggle('toggle-active', !yearly);
      btnY.classList.toggle('toggle-active', yearly);
    }
  }

  document.getElementById('btn-monthly')?.addEventListener('click', () => { yearly = false; updatePrices(); });
  document.getElementById('btn-yearly')?.addEventListener('click',  () => { yearly = true;  updatePrices(); });
</script>

<style>
  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .tier-card { padding: 36px; position: relative; }
  .tier-highlight {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
  }

  .toggle-btn {
    background: transparent;
    color: var(--ink-2);
    cursor: pointer;
    transition: all 160ms;
  }
  .toggle-active {
    background: var(--ink);
    color: var(--cream);
  }

  .features-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .features-list li {
    display: flex;
    gap: 10px;
    font-size: 14px;
    align-items: flex-start;
    color: var(--ink-2);
  }
  .features-list li::before {
    content: '';
    display: inline-block;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    margin-top: 3px;
    background-image: url("data:image/svg+xml;utf8,<svg width='14' height='14' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'><path d='m4 8 3 3 5-6' stroke='%23F26B3A' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/></svg>");
    background-repeat: no-repeat;
    background-size: contain;
  }
  .features-dark li { color: rgba(244,236,219,0.85); }

  .faq-layout {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 64px;
  }
  .faq-list details {
    border-top: 1px solid var(--line);
    padding: 20px 0;
  }
  .faq-list details:last-child { border-bottom: 1px solid var(--line); }
  .faq-list summary {
    cursor: pointer;
    font-size: 18px;
    font-family: var(--font-display);
    font-variation-settings: "SOFT" 50, "WONK" 0, "opsz" 144;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-list summary::-webkit-details-marker { display: none; }
  .faq-list summary span {
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--ink-3);
    flex-shrink: 0;
  }
  .faq-list details[open] summary span { transform: rotate(45deg); }
  .faq-list p { margin-top: 14px; color: var(--ink-2); max-width: 60ch; }

  .cta-dark {
    background: var(--ink);
    color: var(--cream);
    padding: 120px 0;
    position: relative;
    overflow: hidden;
  }

  @media (max-width: 900px) {
    .tiers-grid { grid-template-columns: 1fr; }
    .faq-layout { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
