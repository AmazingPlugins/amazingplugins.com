---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  const posts = [
    { slug: 'woocommerce-bulk-edit-plugins-compared', title: 'The 6 Best WooCommerce Bulk Edit Plugins Compared (2026 Honest Review)', description: 'An honest ranking of the six most downloaded WooCommerce bulk edit plugins — with real performance tests, free version quality checks, and brutal notes on where each one breaks down.', date: 'April 12, 2026', tag: 'WooCommerce' },
    { slug: 'bulk-edit-woocommerce-product-prices', title: 'How to Bulk Edit WooCommerce Product Prices (Without Breaking Your Store)', description: 'A practical guide to updating prices across your entire catalog.', date: 'April 13, 2026', tag: 'WooCommerce' },
    { slug: 'bulk-edit-woocommerce-variations', title: 'How to Bulk Edit WooCommerce Variations (The Right Way)', description: 'Variable products are the most powerful feature in WooCommerce.', date: 'April 13, 2026', tag: 'WooCommerce' },
    { slug: 'woocommerce-bulk-edit-not-working', title: 'WooCommerce Bulk Edit Not Working? Here is Why (And How to Fix It)', description: 'The five most common reasons WooCommerce bulk editing fails.', date: 'April 14, 2026', tag: 'Troubleshooting' },
    { slug: 'woocommerce-ada-compliance', title: 'How to Make Your WooCommerce Store ADA Compliant (2026 Guide)', description: 'The EU European Accessibility Act is now enforceable.', date: 'April 15, 2026', tag: 'Accessibility' },
    { slug: 'shopify-store-accessibility', title: 'How to Make Your Shopify Store Accessible (Step-by-Step)', description: 'A practical guide to WCAG 2.1 AA standards.', date: 'April 15, 2026', tag: 'Accessibility' },
    { slug: 'common-accessibility-issues-ecommerce', title: '10 Common Accessibility Issues on E-commerce Sites (And How to Fix Them)', description: "Based on WebAIM's analysis of 1 million websites.", date: 'April 16, 2026', tag: 'Accessibility' },
    { slug: 'alt-text-keyboard-quick-wins', title: 'Alt Text, Keyboard Navigation, and Other Quick Accessibility Wins', description: 'Five accessibility fixes that take less than 30 minutes each.', date: 'April 16, 2026', tag: 'Accessibility' },
    { slug: 'prepare-woocommerce-store-ada-compliance', title: 'How to Prepare Your WooCommerce Store for ADA Compliance (2026)', description: 'A practical checklist for WooCommerce store owners.', date: 'April 17, 2026', tag: 'Accessibility' },
    { slug: 'wcag-2-1-aa-vs-aaa', title: 'WCAG 2.1 AA vs AAA: What is the Real Difference for E-commerce?', description: 'Most e-commerce businesses only need Level AA compliance.', date: 'April 17, 2026', tag: 'Accessibility' },
    { slug: 'hidden-accessibility-issues-costing-customers', title: 'The Hidden Accessibility Issues Costing Your Store Customers', description: 'The accessibility problems that do not show up in automated scanners.', date: 'April 18, 2026', tag: 'Accessibility' },
    { slug: 'keyboard-navigation-simplest-accessibility-win', title: 'Keyboard Navigation: The Simplest Accessibility Win You Are Missing', description: 'Keyboard navigation is the single highest-impact accessibility fix.', date: 'April 18, 2026', tag: 'Accessibility' },
  ];
  return posts.map(({ slug, title, description, date, tag }) => ({
    params: { slug },
    props: { title, description, date, tag },
  }));
}

const { slug } = Astro.params;
const { title, description, date, tag } = Astro.props;

const allFiles = import.meta.glob('../../../docs/marketing/blog-*.md');
const entry = Object.entries(allFiles).find(([path]) => path.includes(slug));
const mod = entry ? await entry[1]() : null;
const raw = mod?.default ?? '';

// Strip frontmatter (everything up to and including the --- separator)
const dividerIdx = raw.indexOf('\n---\n');
const content = dividerIdx >= 0 ? raw.slice(dividerIdx + 5) : raw;

function renderMarkdown(md) {
  return md
    .replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code class="language-$1">$2</code></pre>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
    .replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>')
    .replace(/^---$/gm, '<hr>')
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    .replace(/^\d+\. (.+)$/gm, '<li>$1</li>')
    .replace(/(<li>.*<\/li>\n?)+/g, '<ul>$&</ul>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>');
}

const paragraphs = renderMarkdown(content);
const contentHtml = `<p>${paragraphs}</p>`;
---

<BaseLayout title={title} description={description}>
  <section class="section">
    <div class="container blog-container">
      <a href="/blog" class="back-link">← Back to Blog</a>
      <article class="blog-post">
        <header class="blog-header">
          <div class="blog-meta">
            <span class="blog-tag">{tag}</span>
            <time class="blog-date">{date}</time>
          </div>
          <h1 class="blog-title">{title}</h1>
          {description && <p class="blog-description">{description}</p>}
        </header>
        <div class="blog-content" set:html={contentHtml} />
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-container { max-width: 740px; margin: 0 auto; }
  .back-link { display: inline-block; margin-bottom: 2rem; color: var(--color-primary); text-decoration: none; font-weight: 600; font-size: 0.9rem; }
  .back-link:hover { text-decoration: underline; }
  .blog-post { background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: 1.5rem; padding: 3rem; }
  .blog-header { margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid var(--color-border); }
  .blog-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; }
  .blog-tag { background: var(--color-primary-bg); color: var(--color-primary); font-size: 0.75rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 999px; }
  .blog-date { color: var(--color-text-light); font-size: 0.8rem; }
  .blog-title { font-size: 2rem; font-weight: 800; line-height: 1.2; margin: 0 0 1rem; color: var(--color-heading); }
  .blog-description { font-size: 1.05rem; color: var(--color-text-light); line-height: 1.6; margin: 0; }
  .blog-content :global(h2) { font-size: 1.5rem; font-weight: 700; margin: 2.5rem 0 1rem; color: var(--color-heading); }
  .blog-content :global(h3) { font-size: 1.2rem; font-weight: 700; margin: 2rem 0 0.75rem; color: var(--color-heading); }
  .blog-content :global(p) { color: var(--color-text); line-height: 1.8; margin: 0 0 1.25rem; }
  .blog-content :global(a) { color: var(--color-primary); text-decoration: underline; }
  .blog-content :global(strong) { font-weight: 700; color: var(--color-heading); }
  .blog-content :global(code) { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 0.3rem; padding: 0.15rem 0.4rem; font-size: 0.85em; color: var(--color-primary); }
  .blog-content :global(pre) { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 0.75rem; padding: 1.25rem; overflow-x: auto; margin: 1.5rem 0; }
  .blog-content :global(pre code) { background: none; border: none; padding: 0; color: var(--color-text); font-size: 0.875rem; }
  .blog-content :global(blockquote) { border-left: 3px solid var(--color-primary); padding: 0.75rem 1.25rem; margin: 1.5rem 0; background: var(--color-primary-bg); border-radius: 0 0.5rem 0.5rem 0; color: var(--color-text-light); font-style: italic; }
  .blog-content :global(ul), .blog-content :global(ol) { margin: 1rem 0 1.25rem 1.5rem; color: var(--color-text); }
  .blog-content :global(li) { line-height: 1.7; margin-bottom: 0.4rem; }
  .blog-content :global(hr) { border: none; border-top: 1px solid var(--color-border); margin: 2.5rem 0; }
</style>
