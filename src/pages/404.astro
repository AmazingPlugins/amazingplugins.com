---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">

  <section class="section text-center">
    <div class="container">
      <div class="error-content">
        <div class="error-code" aria-hidden="true">404</div>
        <h1>Page Not Found</h1>
        <p>The page you're looking for has moved, been deleted, or never existed.</p>
        <div class="error-actions">
          <a href="/" class="btn btn-primary">Go Home</a>
          <a href="/plugins" class="btn btn-outline">View Plugins</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .error-content {
    max-width: 480px;
    margin: 0 auto;
  }

  .error-code {
    font-size: 8rem;
    font-weight: 800;
    color: #e5e7eb;
    line-height: 1;
    margin-bottom: 1rem;
    letter-spacing: -0.05em;
  }

  .error-content h1 {
    margin-bottom: 1rem;
  }

  .error-content p {
    color: var(--color-text-light);
    font-size: 1.125rem;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .error-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }
</style>
